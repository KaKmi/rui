# ============================================================
# Rui · 环境变量模板
# 用法：cp .env.example .env.local 并填入实际值（.env.local 已在 .gitignore）
# ============================================================

# —— DB（Neon Postgres）——
# 在 Neon dashboard 创建项目 → Connection Details → "Pooled connection" 推荐
# 形如：postgres://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgres://user:password@host.neon.tech/rui?sslmode=require"

# —— 文件存储（Vercel Blob）——
# Vercel 部署时自动注入；本地开发用 dashboard 的 "Stores → Blob → Create Token"
BLOB_READ_WRITE_TOKEN=""

# —— LLM（小米 MiMo · Anthropic 兼容）——
MIMO_BASE_URL="https://token-plan-cn.xiaomimimo.com/anthropic/v1"   # 必须带 /v1，SDK 内部会再拼 /messages
MIMO_API_KEY=""                          # 必填：在 .env.local 填入实际密钥
MIMO_MODEL="mimo-v2.5-pro"               # 可选：默认模型 ID
MIMO_TIMEOUT_MS="60000"                  # 可选：单次请求超时（毫秒）

# —— OCR（腾讯云通用印刷体识别）——
# 扫描件 PDF 上传后，pdf-parse 抽不出文字时降级走这里。
# 控制台：https://console.cloud.tencent.com/cam/capi
# 免费额度：1000 次/月
TENCENT_OCR_SECRET_ID=""
TENCENT_OCR_SECRET_KEY=""
TENCENT_OCR_REGION="ap-guangzhou"        # 可选，默认 ap-guangzhou

# —— 应用 ——
NEXT_PUBLIC_AGENT_NAME="Rui"             # 侧栏 / topbar 显示名（spec §6.6.9）
NEXT_PUBLIC_DEFAULT_ACCENT="violet"      # violet | cyan | lime | pink

# —— 调试 ——
LOG_LEVEL="info"
