// Rui · Prisma schema
// 数据库：Neon Postgres（serverless driver）。
// 运行时连接由 lib/db.ts 的 PrismaNeon adapter 提供；迁移命令的连接放 prisma.config.ts。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Job —— spec §7 Job interface
// 业务 ID 形如 "JD-2024-0118"，保留为主键；DB 自动 createdAt。
// ============================================================
model Job {
  id              String   @id                    // "JD-2024-0118"
  title           String
  dept            String
  level           String                          // "P7" / "P6 / P7"
  location        String                          // 多地用 " / " 分隔
  salary          String                          // "30-55K · 16薪"
  type            String                          // '全职' | '实习' | '外包'
  status          String                          // '草稿' | '招聘中' | '已暂停' | '已关闭'
  owner           String                          // 用人经理
  hr              String
  headcount       Int

  // 漏斗（denormalized）—— 这里跟随 spec §7 决策；后续可由触发器维护
  resumes         Int      @default(0)
  interviewed    Int      @default(0)
  offer          Int      @default(0)

  skills          String[]
  description     String   @default("")
  responsibilities String[] @default([])
  requirements    String[] @default([])
  nice            String[] @default([])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  resumeList      Resume[] @relation("ResumeAppliedFor")

  @@index([status])
  @@index([createdAt])
}

// ============================================================
// Resume —— spec §7 Resume interface
//
// 字段分两类：
//   1. M3.1 上传时就有的：id / appliedForId / status / 文件元信息 / parsedText
//   2. M3.2 评分后才填的：name / age / edu / yoe / current / score / breakdown / ...
//      这些在新上传的简历里都是 null，待 score_resume 工具回填。
//
// 为兼容这两阶段，所有"评分后"字段在 schema 里都是 optional；
// 现有 seed 的 10 份简历是"已评分"状态，全字段填好；
// 新上传走 M3.1 → M3.2 两步逐次填。
// ============================================================
model Resume {
  id            String   @id                      // "R-9821" / 上传时自动生成 "R-{nanoid}"
  status        String                            // '解析失败' | '待评分' | 'AI 已评分' | '已邀面' | '已 offer' | '已淘汰'

  // —— 关联 ——
  appliedForId  String                            // FK → Job.id
  appliedFor    Job      @relation("ResumeAppliedFor", fields: [appliedForId], references: [id], onDelete: Restrict)
  appliedAt     String                            // 展示文案 "今天 10:24"；真实时间见 createdAt

  // —— M3.1 上传时落库的文件元信息 ——
  originalFileUrl  String?                        // Vercel Blob URL
  originalFileName String?                        // 用户上传时的文件名
  originalFileSize Int?                           // 字节
  originalMimeType String?                        // application/pdf | application/vnd.openxmlformats-officedocument.wordprocessingml.document
  parsedText       String?                        // pdf-parse / mammoth 抽出的全文；解析失败 = null
  parseError       String?                        // 解析失败原因（用户可见）；ok = null

  // —— M3.2 评分填充的字段（M1.2 mock 数据全字段填好；新上传 = null）——
  name          String?
  gender        String?                           // '男' | '女'
  age           Int?
  edu           String?                           // "硕士 · 浙江大学"
  yoe           Int?
  current       String?                           // "字节跳动 · 高级前端工程师"
  expected      String?                           // "40-55K"
  location      String?
  score         Int?                              // 0-100；null = 未评分
  breakdown     Json?                             // { skill, experience, education, project, stability }
  summary       String?
  pros          String[] @default([])
  cons          String[] @default([])
  interview     String[] @default([])
  skills        String[] @default([])
  workHistory   Json?                             // [{ co, title, dur }]?

  // —— M4 写操作时间戳 ——
  invitedAt     DateTime?                         // 推进到面试时落
  rejectedAt    DateTime?                         // 标记不合适时落
  rejectReason  String?                           // 不合适理由（可选）

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([appliedForId])
  @@index([score])
  @@index([status])
}
